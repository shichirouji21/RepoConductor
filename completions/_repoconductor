#compdef repoconductor
# zsh completion for repoconductor
# Install: copy to a directory on $fpath, e.g. /usr/share/zsh/site-functions/_repoconductor

_repoconductor() {
  local -a args
  args=(
    '(-h --help)'{-h,--help}'[Show this help text]'
    '(-V --version)'{-V,--version}'[Show version and exit]'
    '(-p --path)'{-p,--path}'[Scan DIR instead of the current working directory]:directory:_directories'
    '--no-recurse[Do not recurse: only treat immediate children of the path as candidates]'
    '(-j --jobs)'{-j,--jobs}'[Maximum concurrent git jobs]:jobs (number):(1 2 4 8 16)'
    '--no-startup-refresh[Skip the initial status refresh]'
    '--debug[Verbose failure output (full captured stderr per failure)]'
  )
  _arguments -s -S $args
}

_repoconductor "$@"
